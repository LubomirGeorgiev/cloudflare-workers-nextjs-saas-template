## Cloudflare account/API access
## Required for GitHub Actions deployment and the admin scheduled jobs Queue preview.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

## Github Actions Secrets - NOT NECESSARY FOR LOCAL DEV ENVIRONMENT
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Optional. Raises GitHub REST API rate limits for the stars badge (see src/utils/stats.ts).
GITHUB_TOKEN=

## Cloudflare Worker Secrets
TURNSTILE_SECRET_KEY=

# Go to https://console.cloud.google.com/auth/clients/ and create a new OAuth client ID and secret
# Set the redirect URI to http://localhost:3000/sso/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

### Stripe Configuration
# Get your API keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
